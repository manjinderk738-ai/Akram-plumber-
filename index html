        </div>
        <div class="review-card">
            <div class="stars"><i class="fas fa-star"></i><i class="fas fa-star"></i><i class="fas fa-star"></i><i class="fas fa-star"></i><i class="fas fa-star"></i></div>
            <p class="review-text">"Mr Akram Very nice good to work I'm people satisfied. Professional plumber very low price."</p>
            <div class="reviewer"><div style="background:var(--gold);width:30px;height:30px;border-radius:50%;display:flex;align-items:center;justify-content:center;color:black;font-weight:bold">M</div><span>Local Guide</span></div>
        </div>
        <div class="review-card">
            <div class="stars"><i class="fas fa-star"></i><i class="fas fa-star"></i><i class="fas fa-star"></i><i class="fas fa-star"></i><i class="fas fa-star"></i></div>
            <p class="review-text">"Best plumber in Sector 49. Open 24 hours and very polite behavior."</p>
            <div class="reviewer"><div style="background:var(--gold);width:30px;height:30px;border-radius:50%;display:flex;align-items:center;justify-content:center;color:black;font-weight:bold">R</div><span>Rahul K.</span></div>
        </div>
    </div>
</section>

<!-- CONTACT & MAP -->
<section id="contact">
    <div class="contact-wrapper">
        <div>
            <h2 style="font-size:2.5rem;margin-bottom:20px">Request Service</h2>
