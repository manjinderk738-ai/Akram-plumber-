    <h1 class="anim-text">BORN FROM<br><span style="color:var(--gold)">EXCELLENCE</span></h1>
    <p class="anim-text">Premium Plumbing Solutions in Chandigarh</p>
    <a href="#contact" class="btn anim-text">Book Appointment</a>
</section>

<!-- SERVICES -->
<section id="services">
    <div class="section-title">
        <h2>Our Expertise</h2>
        <span></span>
    </div>
    <div class="services-grid">
        <div class="service-card">
            <img src="https://images.unsplash.com/photo-1584622650111-993a426fbf0a?auto=format&fit=crop&q=80&w=800" alt="Repairs">
            <div class="service-info">
                <h3>Expert Repairs</h3>
                <p>Fast & Reliable fixing for all household leaks.</p>
            </div>
        </div>
        <div class="service-card">
            <img src="https://images.unsplash.com/photo-1507652313519-d4e9174996dd?auto=format&fit=crop&q=80&w=800" alt="Installation">
            <div class="service-info">
                <h3>Luxury Installation</h3>
