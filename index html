                <p style="margin-top:10px"><i class="fas fa-phone" style="color:var(--gold)"></i> 094175 54110</p>
                <p style="margin-top:10px"><i class="fas fa-clock" style="color:var(--gold)"></i> Open 24 Hours</p>
            </div>
        </div
    </div>
</section>

<!-- FOOTER -->
<footer style="text-align:center;padding:40px;border-top:1px solid var(--border);font-size:0.8rem;opacity:0.5">
    &copy; 2024 Akram Plumber. Designed for Excellence.
</footer>

<!-- FLOATING WA BUTTON -->
<a href="https://wa.me/919417554110?text=Hello%20Akram,%20I%20need%20plumbing%20assistance." class="float-wa" target="_blank">
    <i class="fab fa-whatsapp"></i>
</a>

<!-- SCRIPTS (GSAP for Animations) -->
<script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/gsap.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/ScrollTrigger.min.js"></script>
<script>
    // Register ScrollTrigger
    gsap.registerPlugin(ScrollTrigger);

    // Hero Animation
    gsap.to(".anim-text", {y:0, opacity:1, duration:1.5, stagger:0.3, ease:"power4.out"});

    // Service Cards Animation
    gsap.utils.toArray('.service-card').forEach((card, i) => {
        gsap.from(card, {
            scrollTrigger: {trigger: card, start: "top 85%"},
            y: 100, opacity: 0, duration: 1, delay: i * 0.2, ease: "power3.out"
        });
    });

    // WhatsApp Logic
    function sendToWhatsapp(e) {
        e.preventDefault();
        const name = document.getElementById('name').value;
        const service = document.getElementById('service').value;
        const address = document.getElementById('address').value;
        const msg = document.getElementById('message').value;
        
        const text = `*New Booking Request*%0A%0A*Name:* ${name}%0A*Service:* ${service}%0A*Address:* ${address}%0A*Details:* ${msg}`;
        
        window.open(`https://wa.me/919417554110?text=${text}`, '_blank');
    }
</script>
</body>
</html>
